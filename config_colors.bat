@echo off
REM ============================================
REM Configuración de Colores para Terminal
REM ============================================

REM Verde para éxito
set COLOR_OK=0A
REM Amarillo para advertencia
set COLOR_WARN=0E
REM Rojo para error
set COLOR_ERR=0C
REM Azul para info
set COLOR_INFO=0B
REM Magenta para títulos
set COLOR_TITLE=0D

REM Símbolos
set ICON_OK=[OK]
set ICON_WARN=[!]
set ICON_ERR=[ERROR]
set ICON_INFO=[INFO]
set ICON_WAIT=[ESPERA]
set ICON_STEP=[->]

REM Colores de la terminal
color 0A
