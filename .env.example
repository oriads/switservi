# ============================================
# HelpDesk IBM i - Variables de Entorno
# Copiar este archivo a .env y configurar
# ============================================

# ============================================
# Base de Datos PostgreSQL
# ============================================
DB_PASSWORD=helpdesk_secure_pass_2024
DB_PORT=5432

# pgAdmin
PGADMIN_EMAIL=admin@helpdesk.com
PGADMIN_PASSWORD=admin_secure_pass_2024
PGADMIN_PORT=5050

# ============================================
# IBM i (AS/400) Configuration
# ============================================
# IMPORTANTE: Configurar con datos reales del servidor IBM i
IBMI_HOST=192.168.1.100
IBMI_PORT=446
IBMI_USER=QSECOFR
IBMI_PASSWORD=your_ibmi_password
IBMI_LIBRARY=QGPL

# ============================================
# API Node.js
# ============================================
NODE_PORT=2050
NODE_ENV=development
CORS_ORIGIN=*
MAX_FILE_SIZE=10485760

# JWT Secret (Cambiar en producción)
JWT_SECRET=cambia-esto-por-una-clave-secreta-muy-larga-y-aleatoria

# Encryption Key para credenciales IBM i (32 caracteres mínimo)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=genera-una-clave-segura-de-32-caracteres-aqui

# ============================================
# Backend Go
# ============================================
GO_BACKEND_PORT=8080

# ============================================
# Frontend React
# ============================================
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000/api

# ============================================
# DSN ODBC Personalizado (opcional)
# Si se proporciona, se usa en lugar del DSN dinámico
# ============================================
# IBMI_DSN=DRIVER={iSeries Access ODBC Driver};SYSTEM=192.168.1.100;...
